{
  "name": "autocheck-backend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only --files src/server.ts",
    "worker": "node dist/worker.js",
    "worker:dev": "ts-node-dev --respawn --transpile-only --files src/worker.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "migrate": "ts-node --files src/db/migrate.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.27.0",
    "@itgenio/edik-core": "^0.0.142",
    "bullmq": "^5.1.1",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "csurf": "^1.11.0",
    "dotenv": "^16.4.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "ioredis": "^5.3.2",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.11.3",
    "reflect-metadata": "^0.2.2",
    "simpleddp": "^2.2.3",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^20.11.0",
    "@types/pg": "^8.11.0",
    "@types/ws": "^8.5.10",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.3"
  }
}
