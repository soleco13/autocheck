# ── Database ────────────────────────────────────────────────────────────────
# PostgreSQL connection string. Create DB: createdb autocheck
DATABASE_URL=postgresql://postgres:PASSWORD@localhost:5432/autocheck

# ── Redis ────────────────────────────────────────────────────────────────────
# Requires Redis/Memurai >= 5.0.0 for BullMQ queue.
REDIS_URL=redis://127.0.0.1:6379

# ── Security (generate with: openssl rand -hex 32) ──────────────────────────
JWT_SECRET=replace_with_64_char_random_hex
TOKEN_ENCRYPTION_KEY=replace_with_64_char_random_hex

# ── Anthropic / Claude API ───────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_BASE_URL=https://api.anthropic.com

# ── Server ───────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# ── Worker ───────────────────────────────────────────────────────────────────
INLINE_WORKER=true
WORKER_CONCURRENCY=3
AI_CONCURRENCY=5

# ── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=info
